{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "vitest/globals"]
  },
  "include": [
    "apps/web/src/**/*.ts",
    "apps/web/src/**/*.tsx",
    "apps/desktop/src/renderer/**/*.ts",
    "apps/desktop/src/renderer/**/*.tsx",
    "packages/app/src/**/*.ts",
    "packages/app/src/**/*.tsx",
    "packages/app/tests/**/*.ts",
    "packages/app/tests/**/*.tsx",
    "packages/platform/src/**/*.ts",
    "packages/platform/src/**/*.tsx",
    "packages/product-runtime/src/**/*.ts",
    "packages/product-runtime/src/**/*.tsx",
    "tests/**/*.ts",
    "tests/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "out",
    "coverage",
    "workspace-shared-docs",
    "**/*.node.test.ts",
    "**/*.node.test.tsx"
  ]
}
