          "$ref": "#/$defs/OpaqueId"
        },
        "created_at": {
          "$ref": "#/$defs/Timestamp"
        },
        "updated_at": {
          "$ref": "#/$defs/Timestamp"
        },
        "revision": {
          "type": "integer",
          "minimum": 1
        },
        "workspace_id": {
