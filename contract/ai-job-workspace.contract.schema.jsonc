            "knowledge.sync",
            "knowledge.delete"
          ]
        },
        "status": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]*$",
          "x-known-values": [
            "queued",
            "running",
            "succeeded",
            "failed",
            "cancelled",
            "expired"
          ]
        },
        "progress": {
          "$ref": "#/$defs/JobProgress"
        },
        "created_at": {
          "$ref": "#/$defs/Timestamp"
        },
        "started_at": {
          "anyOf": [
            {
              "$ref": "#/$defs/Timestamp"
            },
            {
              "type": "null"
            }
          ]
        },
        "finished_at": {
          "anyOf": [
            {
              "$ref": "#/$defs/Timestamp"
            },
            {
              "type": "null"
            }
          ]
        },
        "expires_at": {
          "anyOf": [
            {
              "$ref": "#/$defs/Timestamp"
            },
            {
              "type": "null"
            }
          ]
        },
        "error": {
          "anyOf": [
            {
              "$ref": "#/$defs/ProblemDetails"
            },
            {
              "type": "null"
            }
          ]
        },
        "request_id": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 8,
              "maxLength": 128
            },
            {
              "type": "null"
            }
          ]
        },
        "extensions": {
          "$ref": "#/$defs/Extensions"
        },
        "source_id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "source_version_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/OpaqueId"
            },
            {
              "type": "null"
            }
          ]
        },
        "stats": {
          "type": "object",
          "properties": {
            "documents": {
              "type": "integer",
              "minimum": 0
            },
            "chunks": {
              "type": "integer",
              "minimum": 0
            },
            "embedded_tokens": {
              "type": "integer",
              "minimum": 0
            },
            "skipped": {
              "type": "integer",
              "minimum": 0
            }
          },
          "required": [
            "documents",
            "chunks",
            "embedded_tokens",
            "skipped"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "id",
        "job_type",
        "status",
        "progress",
        "created_at",
        "source_id",
        "stats"
      ],
      "additionalProperties": false
    },
