    "ResumeSourceConfig": {
      "type": "object",
      "properties": {
        "source_type": {
          "type": "string",
          "const": "resume"
        },
        "resume_id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "revision_mode": {
          "type": "string",
          "enum": [
            "latest",
            "pinned"
          ]
        },
        "pinned_revision": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "source_type",
        "resume_id",
        "revision_mode"
      ],
      "additionalProperties": false
    },
    "FileSourceConfig": {
      "type": "object",
      "properties": {
        "source_type": {
          "type": "string",
          "const": "file"
        },
        "file_id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "filename": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        },
        "content_type": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "sha256": {
          "$ref": "#/$defs/Sha256"
        }
      },
      "required": [
        "source_type",
        "file_id",
        "filename",
        "content_type",
        "sha256"
      ],
      "additionalProperties": false
    },
    "UrlSourceConfig": {
      "type": "object",
      "properties": {
        "source_type": {
          "type": "string",
          "enum": [
            "url",
            "website",
            "blog_feed"
          ]
        },
        "url": {
          "$ref": "#/$defs/Uri"
        },
        "crawl_depth": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "max_pages": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100000
        },
        "include_patterns": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 1000
          },
          "maxItems": 100
        },
        "exclude_patterns": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 1000
          },
          "maxItems": 100
        },
        "connection_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/OpaqueId"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "source_type",
        "url",
        "crawl_depth",
        "max_pages"
      ],
      "additionalProperties": false
    },
    "GitRepositorySourceConfig": {
      "type": "object",
      "properties": {
        "source_type": {
          "type": "string",
          "const": "git_repository"
        },
        "repository_url": {
          "$ref": "#/$defs/Uri"
        },
        "default_branch": {
          "anyOf": [
            {
              "type": "string",
              "maxLength": 300
            },
            {
              "type": "null"
            }
          ]
        },
        "ref": {
          "anyOf": [
            {
              "type": "string",
              "maxLength": 300
            },
            {
              "type": "null"
            }
          ]
        },
        "include_globs": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 500
          },
          "maxItems": 500
        },
        "exclude_globs": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 500
          },
          "maxItems": 500
        },
        "include_history": {
          "type": "boolean",
          "default": false
        },
        "connection_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/OpaqueId"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "source_type",
        "repository_url",
        "include_history"
      ],
      "additionalProperties": false
    },
    "CloudDriveSourceConfig": {
      "type": "object",
      "properties": {
        "source_type": {
          "type": "string",
          "const": "cloud_drive"
        },
        "provider": {
          "type": "string",
          "enum": [
            "google_drive",
            "microsoft_onedrive",
            "dropbox",
            "other"
          ]
        },
        "connection_id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "root_id": {
          "anyOf": [
            {
              "type": "string",
              "maxLength": 2000
            },
            {
              "type": "null"
            }
          ]
        },
        "include_globs": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 500
          },
          "maxItems": 500
        },
        "exclude_globs": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 500
          },
          "maxItems": 500
        }
      },
      "required": [
        "source_type",
        "provider",
        "connection_id"
      ],
      "additionalProperties": false
    },
    "ManualNoteSourceConfig": {
      "type": "object",
      "properties": {
        "source_type": {
          "type": "string",
          "const": "manual_note"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300
        },
        "content": {
          "$ref": "#/$defs/RichText"
        }
      },
      "required": [
        "source_type",
        "title",
        "content"
      ],
      "additionalProperties": false
    },
    "KnowledgeSourceConfig": {
      "oneOf": [
        {
          "$ref": "#/$defs/ResumeSourceConfig"
        },
        {
          "$ref": "#/$defs/FileSourceConfig"
        },
        {
          "$ref": "#/$defs/UrlSourceConfig"
        },
        {
          "$ref": "#/$defs/GitRepositorySourceConfig"
        },
        {
          "$ref": "#/$defs/CloudDriveSourceConfig"
        },
        {
          "$ref": "#/$defs/ManualNoteSourceConfig"
        }
      ]
    },
    "KnowledgeIngestionState": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "not_started",
            "queued",
            "fetching",
            "parsing",
            "chunking",
            "embedding",
            "ready",
            "stale",
            "failed",
            "deleted"
          ]
        },
        "active_job_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/OpaqueId"
            },
            {
              "type": "null"
            }
          ]
        },
        "indexed_version_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/OpaqueId"
            },
            {
              "type": "null"
            }
          ]
        },
        "document_count": {
          "type": "integer",
          "minimum": 0
        },
        "chunk_count": {
          "type": "integer",
          "minimum": 0
        },
        "last_success_at": {
          "anyOf": [
            {
              "$ref": "#/$defs/Timestamp"
            },
            {
              "type": "null"
            }
          ]
        },
        "last_error": {
          "anyOf": [
            {
              "$ref": "#/$defs/ProblemDetails"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "status",
        "document_count",
        "chunk_count"
      ],
      "additionalProperties": false
    },
    "SyncSchedule": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "manual",
            "interval",
            "cron",
            "webhook"
          ]
        },
        "interval_minutes": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 5,
              "maximum": 525600
            },
            {
              "type": "null"
            }
          ]
        },
        "cron": {
          "anyOf": [
            {
              "type": "string",
              "maxLength": 200
            },
            {
              "type": "null"
            }
          ]
        },
        "enabled": {
          "type": "boolean",
          "default": true
        }
      },
      "required": [
        "mode",
        "enabled"
      ],
      "additionalProperties": false
    },
    "KnowledgeSource": {
      "type": "object",
      "properties": {
        "id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "created_at": {
          "$ref": "#/$defs/Timestamp"
        },
        "updated_at": {
          "$ref": "#/$defs/Timestamp"
        },
        "revision": {
          "type": "integer",
          "minimum": 1
        },
        "workspace_id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300
        },
        "source_type": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]*$",
          "x-known-values": [
            "resume",
            "file",
            "url",
            "website",
            "blog_feed",
            "git_repository",
            "manual_note",
            "cloud_drive"
          ]
        },
        "config": {
          "$ref": "#/$defs/KnowledgeSourceConfig"
        },
        "visibility": {
          "$ref": "#/$defs/KnowledgeVisibilityPolicy"
        },
        "ingestion": {
          "$ref": "#/$defs/KnowledgeIngestionState"
        },
        "sync_schedule": {
          "anyOf": [
            {
              "$ref": "#/$defs/SyncSchedule"
            },
            {
              "type": "null"
            }
          ]
        },
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "extensions": {
          "$ref": "#/$defs/Extensions"
        }
      },
      "required": [
        "id",
        "created_at",
        "updated_at",
        "revision",
        "workspace_id",
        "name",
        "source_type",
        "config",
        "visibility",
        "ingestion",
        "enabled"
      ],
      "additionalProperties": false
    },
    "KnowledgeSourceVersion": {
      "type": "object",
      "properties": {
        "id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "source_id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "version_number": {
          "type": "integer",
          "minimum": 1
        },
        "content_sha256": {
          "$ref": "#/$defs/Sha256"
        },
        "created_at": {
          "$ref": "#/$defs/Timestamp"
        },
        "provenance": {
          "type": "object",
          "properties": {
            "origin": {
              "anyOf": [
                {
                  "$ref": "#/$defs/Uri"
                },
                {
                  "type": "null"
                }
              ]
            },
            "retrieved_at": {
              "anyOf": [
                {
                  "$ref": "#/$defs/Timestamp"
                },
                {
                  "type": "null"
                }
              ]
            },
            "source_revision": {
              "anyOf": [
                {
                  "type": "string",
                  "maxLength": 500
                },
                {
                  "type": "null"
                }
              ]
            }
          },
          "additionalProperties": false
        },
        "status": {
          "type": "string",
          "enum": [
            "available",
            "superseded",
            "deleted"
          ]
        }
      },
      "required": [
        "id",
        "source_id",
        "version_number",
        "content_sha256",
        "created_at",
        "provenance",
        "status"
      ],
      "additionalProperties": false
    },
    "KnowledgeSelection": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "policy_default",
            "explicit",
            "none"
          ]
        },
        "include_source_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/OpaqueId"
          },
          "maxItems": 1000,
          "uniqueItems": true
        },
        "exclude_source_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/OpaqueId"
          },
          "maxItems": 1000,
          "uniqueItems": true
        },
        "pinned_versions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "source_id": {
                "$ref": "#/$defs/OpaqueId"
              },
              "version_id": {
                "$ref": "#/$defs/OpaqueId"
              }
            },
            "required": [
              "source_id",
              "version_id"
            ],
            "additionalProperties": false
          },
          "maxItems": 1000
        },
        "agent_scope": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]*$",
          "x-known-values": [
            "resume_assistant",
            "job_fit_analyst",
            "interview_agent",
            "interview_reporter",
            "general_chat",
            "portfolio_assistant"
          ]
        }
      },
      "required": [
        "mode",
        "include_source_ids",
        "exclude_source_ids",
        "pinned_versions",
        "agent_scope"
      ],
      "additionalProperties": false
    },
    "KnowledgeCitation": {
      "type": "object",
      "properties": {
        "citation_id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "source_id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "source_version_id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "uri": {
          "anyOf": [
            {
              "$ref": "#/$defs/Uri"
            },
            {
              "type": "null"
            }
          ]
        },
        "locator": {
          "type": "object",
          "properties": {
            "page": {
              "anyOf": [
                {
                  "type": "integer",
                  "minimum": 1
                },
                {
                  "type": "null"
                }
              ]
            },
            "line_start": {
              "anyOf": [
                {
                  "type": "integer",
                  "minimum": 1
                },
                {
                  "type": "null"
                }
              ]
            },
            "line_end": {
              "anyOf": [
                {
                  "type": "integer",
                  "minimum": 1
                },
                {
                  "type": "null"
                }
              ]
            },
            "time_start_ms": {
              "anyOf": [
                {
                  "type": "integer",
                  "minimum": 0
                },
                {
                  "type": "null"
                }
              ]
            },
            "time_end_ms": {
              "anyOf": [
                {
                  "type": "integer",
                  "minimum": 0
                },
                {
                  "type": "null"
                }
              ]
            },
            "symbol": {
              "anyOf": [
                {
                  "type": "string",
                  "maxLength": 500
                },
                {
                  "type": "null"
                }
              ]
            },
            "path": {
              "anyOf": [
                {
                  "type": "string",
                  "maxLength": 2000
                },
                {
                  "type": "null"
                }
              ]
            }
          },
          "additionalProperties": false
        },
        "quote": {
          "anyOf": [
            {
              "type": "string",
              "maxLength": 4000
            },
            {
              "type": "null"
            }
          ]
        },
        "score": {
          "anyOf": [
            {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "citation_id",
        "source_id",
        "source_version_id",
        "title",
        "locator"
      ],
      "additionalProperties": false
    },
    "KnowledgeSearchRequest": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "minLength": 1,
          "maxLength": 10000
        },
        "selection": {
          "$ref": "#/$defs/KnowledgeSelection"
        },
        "top_k": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "filters": {
          "type": "object",
          "additionalProperties": true
        },
        "include_quotes": {
          "type": "boolean",
          "default": true
        }
      },
      "required": [
        "query",
        "selection",
        "top_k",
        "include_quotes"
      ],
      "additionalProperties": false
    },
    "KnowledgeSearchResult": {
      "type": "object",
      "properties": {
        "result_id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "citation": {
          "$ref": "#/$defs/KnowledgeCitation"
        },
        "text": {
          "type": "string",
          "maxLength": 50000
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "required": [
        "result_id",
        "citation",
        "text",
        "score"
      ],
      "additionalProperties": false
    },
