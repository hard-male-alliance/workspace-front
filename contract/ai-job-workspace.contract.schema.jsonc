    "RichText": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "1.0"
        },
        "blocks": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "$ref": "#/$defs/ParagraphBlock"
              },
              {
                "$ref": "#/$defs/ListBlock"
              }
            ]
          },
          "maxItems": 1000
        },
        "plain_text": {
          "anyOf": [
            {
              "type": "string",
              "maxLength": 200000,
              "description": "Optional server-normalized search/indexing projection."
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "schema_version",
        "blocks"
      ],
      "additionalProperties": false,
      "description": "Portable semantic rich text. HTML, Markdown, ProseMirror JSON and LaTeX are deliberately excluded from the wire contract."
    },
