          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]*$",
          "x-known-values": [
            "owner",
            "admin",
            "editor",
            "viewer"
          ]
        },
        "status": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]*$",
