// AI Job Workspace public contract — JSON Schema Draft 2020-12.
// This file is JSONC: strip comments before feeding it to strict JSON parsers.
// Normative rule: clients depend on semantic intents and events, never renderer/model-provider internals.
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.example.com/ai-job-workspace/v1/workspace-contract.schema.json",
  "title": "AI Job Workspace Contract Bundle",
  "description": "Compound JSON Schema bundle for the public REST/SSE/WebRTC control contract. Validate concrete payloads via x-entrypoints or direct $defs references.",
  "$comment": "JSONC comments are non-normative. Renderer implementation, model provider names, vector database details and private credentials are intentionally absent.",
  "x-contract-version": "1.0.0",
  "x-entrypoints": {
    "ProblemDetails": "#/$defs/ProblemDetails",
    "CurrentUser": "#/$defs/CurrentUser",
    "ExternalConnection": "#/$defs/ExternalConnection",
    "ConnectionAuthorizationSession": "#/$defs/ConnectionAuthorizationSession",
    "AuditEvent": "#/$defs/AuditEvent",
    "ResumeDocument": "#/$defs/ResumeDocument",
    "TemplateManifest": "#/$defs/TemplateManifest",
    "ResumeOperationBatch": "#/$defs/ResumeOperationBatch",
    "ResumeOperationBatchResult": "#/$defs/ResumeOperationBatchResult",
    "RenderJobRequest": "#/$defs/RenderJobRequest",
    "ResumeRenderJob": "#/$defs/ResumeRenderJob",
    "PdfSourceMap": "#/$defs/PdfSourceMap",
    "Conversation": "#/$defs/Conversation",
    "ChatMessage": "#/$defs/ChatMessage",
    "AgentRunRequest": "#/$defs/AgentRunRequest",
    "AgentRun": "#/$defs/AgentRun",
    "AgentEventEnvelopeBase": "#/$defs/AgentEventEnvelopeBase",
    "AgentStreamEvent": "#/$defs/AgentStreamEvent",
    "InterviewSessionCreateRequest": "#/$defs/InterviewSessionCreateRequest",
    "InterviewSession": "#/$defs/InterviewSession",
    "RealtimeConnectionDescriptor": "#/$defs/RealtimeConnectionDescriptor",
    "InterviewEventEnvelopeBase": "#/$defs/InterviewEventEnvelopeBase",
    "InterviewRealtimeEvent": "#/$defs/InterviewRealtimeEvent",
    "InterviewReport": "#/$defs/InterviewReport",
    "KnowledgeSource": "#/$defs/KnowledgeSource",
    "KnowledgeSelection": "#/$defs/KnowledgeSelection",
    "KnowledgeIngestionJob": "#/$defs/KnowledgeIngestionJob",
    "UploadSession": "#/$defs/UploadSession"
  },
  "$defs": {
    "OpaqueId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]{7,127}$",
      "description": "Opaque, stable resource identifier. Clients must not infer semantics from the value.",
      "examples": [
        "res_01JZZZZZZZZZZZZZZZZZZZZZZZ"
      ]
    },
    "Timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 timestamp, serialized in UTC whenever possible."
    },
    "Locale": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,3}(?:-[A-Za-z0-9]{2,8})*$",
      "examples": [
        "zh-CN",
        "en-US"
      ]
    },
    "Uri": {
      "type": "string",
      "format": "uri"
    },
    "Sha256": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "Extensions": {
      "type": "object",
      "description": "Namespaced extension bag. Keys should use reverse-domain or vendor.feature notation.",
      "propertyNames": {
        "pattern": "^[A-Za-z][A-Za-z0-9_.-]{2,127}$"
      },
      "additionalProperties": true,
      "default": {}
    },
    "ResourceRef": {
      "type": "object",
      "properties": {
        "resource_type": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]*$",
          "x-known-values": [
            "workspace",
            "resume",
            "resume_revision",
            "template",
            "conversation",
            "message",
            "agent_run",
            "interview_session",
            "knowledge_source",
            "knowledge_source_version",
            "file",
            "job"
          ]
        },
        "id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "revision": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "resource_type",
        "id"
      ],
      "additionalProperties": false
    },
    "VersionedRef": {
      "type": "object",
      "properties": {
        "id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      },
      "required": [
        "id",
        "version"
      ],
      "additionalProperties": false
    },
    "LocalizedMessage": {
      "type": "object",
      "properties": {
        "message_key": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]*$"
        },
        "fallback_message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "params": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "required": [
        "message_key",
        "fallback_message"
      ],
      "additionalProperties": false
    },
    "FieldViolation": {
      "type": "object",
      "properties": {
        "pointer": {
          "type": "string",
          "description": "JSON Pointer to the invalid field."
        },
        "code": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]*$"
        },
        "message": {
          "$ref": "#/$defs/LocalizedMessage"
        },
        "rejected_value": {}
      },
      "required": [
        "pointer",
        "code",
        "message"
      ],
      "additionalProperties": false
    },
    "ProblemDetails": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "format": "uri-reference"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "status": {
          "type": "integer",
          "minimum": 400,
          "maximum": 599
        },
        "detail": {
          "anyOf": [
            {
              "type": "string",
              "maxLength": 4000
            },
            {
              "type": "null"
            }
          ]
        },
        "instance": {
          "anyOf": [
            {
              "type": "string",
              "format": "uri-reference"
            },
            {
              "type": "null"
            }
          ]
        },
        "code": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]*$"
        },
        "request_id": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 8,
              "maxLength": 128
            },
            {
              "type": "null"
            }
          ]
        },
        "retryable": {
          "type": "boolean",
          "default": false
        },
        "retry_after_ms": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0
            },
            {
              "type": "null"
            }
          ]
        },
        "violations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/FieldViolation"
          }
        },
        "extensions": {
          "$ref": "#/$defs/Extensions"
        }
      },
      "required": [
        "type",
        "title",
        "status",
        "code",
        "retryable"
      ],
      "additionalProperties": false,
      "description": "RFC 9457-compatible problem details with stable application error codes."
    },
    "CursorPage": {
      "type": "object",
      "properties": {
        "next_cursor": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 2048
            },
            {
              "type": "null"
            }
          ]
        },
        "has_more": {
          "type": "boolean"
        },
        "total_estimate": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "has_more"
      ],
      "additionalProperties": false
    },
    "Link": {
      "type": "object",
      "properties": {
        "label": {
          "anyOf": [
            {
              "type": "string",
              "maxLength": 200
            },
            {
              "type": "null"
            }
          ]
        },
        "url": {
          "$ref": "#/$defs/Uri"
        },
        "kind": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]*$",
          "x-known-values": [
            "website",
            "email",
            "phone",
            "linkedin",
            "github",
            "portfolio",
            "publication",
            "other"
          ]
        }
      },
      "required": [
        "url",
        "kind"
      ],
      "additionalProperties": false
    },
    "PartialDate": {
      "type": "object",
      "properties": {
        "year": {
          "type": "integer",
          "minimum": 1900,
          "maximum": 2200
        },
        "month": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 1,
              "maximum": 12
            },
            {
              "type": "null"
            }
          ]
        },
        "day": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 1,
              "maximum": 31
            },
            {
              "type": "null"
            }
          ]
        },
        "precision": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]*$",
          "x-known-values": [
            "year",
            "month",
            "day"
          ]
        }
      },
      "required": [
        "year",
        "precision"
      ],
      "additionalProperties": false
    },
    "DateRange": {
      "type": "object",
      "properties": {
        "start": {
          "anyOf": [
            {
              "$ref": "#/$defs/PartialDate"
            },
            {
              "type": "null"
            }
          ]
        },
        "end": {
          "anyOf": [
            {
              "$ref": "#/$defs/PartialDate"
            },
            {
              "type": "null"
            }
          ]
        },
        "is_current": {
          "type": "boolean",
          "default": false
        },
        "display_override": {
          "anyOf": [
            {
              "type": "string",
              "maxLength": 100
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "is_current"
      ],
      "additionalProperties": false
    },
    "Measurement": {
      "type": "object",
      "properties": {
        "value": {
          "type": "number",
          "minimum": 0
        },
        "unit": {
          "type": "string",
          "enum": [
            "pt",
            "mm",
            "cm",
            "in",
            "px",
            "em",
            "percent"
          ]
        }
      },
      "required": [
        "value",
        "unit"
      ],
      "additionalProperties": false
    },
    "EdgeInsets": {
      "type": "object",
      "properties": {
        "top": {
          "$ref": "#/$defs/Measurement"
        },
        "right": {
          "$ref": "#/$defs/Measurement"
        },
        "bottom": {
          "$ref": "#/$defs/Measurement"
        },
        "left": {
          "$ref": "#/$defs/Measurement"
        }
      },
      "required": [
        "top",
        "right",
        "bottom",
        "left"
      ],
      "additionalProperties": false
    },
    "ColorValue": {
      "type": "object",
      "properties": {
        "space": {
          "type": "string",
          "enum": [
            "srgb_hex",
            "rgba"
          ]
        },
        "value": {
          "type": "string",
          "pattern": "^(#[0-9A-Fa-f]{6}|#[0-9A-Fa-f]{8}|rgba\\([^\\)]+\\))$"
        }
      },
      "required": [
        "space",
        "value"
      ],
      "additionalProperties": false
    },
    "JobProgress": {
      "type": "object",
      "properties": {
        "phase": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]*$",
          "x-known-values": [
            "queued",
            "validating",
            "preparing",
            "processing",
            "rendering",
            "uploading",
            "indexing",
            "finalizing",
            "done"
          ]
        },
        "completed_units": {
          "type": "integer",
          "minimum": 0
        },
        "total_units": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "percent": {
          "anyOf": [
            {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            {
              "type": "null"
            }
          ]
        },
        "message": {
          "anyOf": [
            {
              "$ref": "#/$defs/LocalizedMessage"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "phase",
        "completed_units"
      ],
      "additionalProperties": false
    },
    "Job": {
      "type": "object",
      "properties": {
        "id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "job_type": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]*$",
          "x-known-values": [
            "resume.render",
            "resume.import",
            "resume.template_migration",
            "knowledge.ingest",
            "knowledge.sync",
            "knowledge.delete",
            "interview.report",
            "interview.recording_finalize",
            "agent.run"
          ]
        },
        "status": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]*$",
          "x-known-values": [
            "queued",
            "running",
            "succeeded",
            "failed",
            "cancelled",
            "expired"
          ]
        },
        "progress": {
          "$ref": "#/$defs/JobProgress"
        },
        "created_at": {
          "$ref": "#/$defs/Timestamp"
        },
        "started_at": {
          "anyOf": [
            {
              "$ref": "#/$defs/Timestamp"
            },
            {
              "type": "null"
            }
          ]
        },
        "finished_at": {
          "anyOf": [
            {
              "$ref": "#/$defs/Timestamp"
            },
            {
              "type": "null"
            }
          ]
        },
        "expires_at": {
          "anyOf": [
            {
              "$ref": "#/$defs/Timestamp"
            },
            {
              "type": "null"
            }
          ]
        },
        "error": {
          "anyOf": [
            {
              "$ref": "#/$defs/ProblemDetails"
            },
            {
              "type": "null"
            }
          ]
        },
        "request_id": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 8,
              "maxLength": 128
            },
            {
              "type": "null"
            }
          ]
        },
        "extensions": {
          "$ref": "#/$defs/Extensions"
        }
      },
      "required": [
        "id",
        "job_type",
        "status",
        "progress",
        "created_at"
      ],
      "additionalProperties": false
    },
    "ApiEvent": {
      "type": "object",
      "properties": {
        "event_id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "event_type": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]*$",
          "x-known-values": [
            "resource.created",
            "resource.updated",
            "resource.deleted",
            "job.updated",
            "notification.created"
          ]
        },
        "occurred_at": {
          "$ref": "#/$defs/Timestamp"
        },
        "resource": {
          "anyOf": [
            {
              "$ref": "#/$defs/ResourceRef"
            },
            {
              "type": "null"
            }
          ]
        },
        "data": {},
        "trace_id": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 8,
              "maxLength": 128
            },
            {
              "type": "null"
            }
          ]
        },
        "extensions": {
          "$ref": "#/$defs/Extensions"
        }
      },
      "required": [
        "event_id",
        "event_type",
        "occurred_at",
        "data"
      ],
      "additionalProperties": false
    },
    "CurrentUser": {
      "type": "object",
      "properties": {
        "id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "display_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "email": {
          "anyOf": [
            {
              "type": "string",
              "format": "email"
            },
            {
              "type": "null"
            }
          ]
        },
        "locale": {
          "$ref": "#/$defs/Locale"
        },
        "timezone": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "default_workspace_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/OpaqueId"
            },
            {
              "type": "null"
            }
          ]
        },
        "created_at": {
          "$ref": "#/$defs/Timestamp"
        }
      },
      "required": [
        "id",
        "display_name",
        "locale",
        "timezone",
        "created_at"
      ],
      "additionalProperties": false
    },
    "ExternalConnection": {
      "type": "object",
      "properties": {
        "id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "created_at": {
          "$ref": "#/$defs/Timestamp"
        },
        "updated_at": {
          "$ref": "#/$defs/Timestamp"
        },
        "revision": {
          "type": "integer",
          "minimum": 1
        },
        "workspace_id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "provider": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]*$",
          "x-known-values": [
            "github",
            "gitlab",
            "gitee",
            "google_drive",
            "microsoft_onedrive",
            "dropbox",
            "generic_git",
            "generic_http"
          ]
        },
        "display_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "reauthorization_required",
            "revoked",
            "failed"
          ]
        },
        "granted_scopes": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 300
          },
          "maxItems": 200,
          "uniqueItems": true
        },
        "expires_at": {
          "anyOf": [
            {
              "$ref": "#/$defs/Timestamp"
            },
            {
              "type": "null"
            }
          ]
        },
        "last_verified_at": {
          "anyOf": [
            {
              "$ref": "#/$defs/Timestamp"
            },
            {
              "type": "null"
            }
          ]
        },
        "problem": {
          "anyOf": [
            {
              "$ref": "#/$defs/ProblemDetails"
            },
            {
              "type": "null"
            }
          ]
        },
        "extensions": {
          "$ref": "#/$defs/Extensions"
        }
      },
      "required": [
        "id",
        "created_at",
        "updated_at",
        "revision",
        "workspace_id",
        "provider",
        "display_name",
        "status",
        "granted_scopes"
      ],
      "additionalProperties": false
    },
    "ConnectionAuthorizationSession": {
      "type": "object",
      "properties": {
        "id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "workspace_id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "provider": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]*$",
          "x-known-values": [
            "github",
            "gitlab",
            "gitee",
            "google_drive",
            "microsoft_onedrive",
            "dropbox"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "created",
            "waiting_for_user",
            "authorized",
            "failed",
            "expired",
            "cancelled"
          ]
        },
        "authorization_url": {
          "anyOf": [
            {
              "$ref": "#/$defs/Uri"
            },
            {
              "type": "null"
            }
          ]
        },
        "user_code": {
          "anyOf": [
            {
              "type": "string",
              "maxLength": 300
            },
            {
              "type": "null"
            }
          ]
        },
        "verification_uri": {
          "anyOf": [
            {
              "$ref": "#/$defs/Uri"
            },
            {
              "type": "null"
            }
          ]
        },
        "expires_at": {
          "$ref": "#/$defs/Timestamp"
        },
        "connection_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/OpaqueId"
            },
            {
              "type": "null"
            }
          ]
        },
        "problem": {
          "anyOf": [
            {
              "$ref": "#/$defs/ProblemDetails"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "id",
        "workspace_id",
        "provider",
        "status",
        "expires_at"
      ],
      "additionalProperties": false
    },
    "AuditEvent": {
      "type": "object",
      "properties": {
        "id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "workspace_id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "occurred_at": {
          "$ref": "#/$defs/Timestamp"
        },
        "actor": {
          "anyOf": [
            {
              "$ref": "#/$defs/ResourceRef"
            },
            {
              "type": "null"
            }
          ]
        },
        "action": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]*$"
        },
        "resource": {
          "anyOf": [
            {
              "$ref": "#/$defs/ResourceRef"
            },
            {
              "type": "null"
            }
          ]
        },
        "outcome": {
          "type": "string",
          "enum": [
            "success",
            "denied",
            "failed"
          ]
        },
        "request_id": {
          "anyOf": [
            {
              "type": "string",
              "maxLength": 128
            },
            {
              "type": "null"
            }
          ]
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "required": [
        "id",
        "workspace_id",
        "occurred_at",
        "action",
        "outcome",
        "metadata"
      ],
      "additionalProperties": false
    },
    "Workspace": {
      "type": "object",
      "properties": {
        "id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "created_at": {
          "$ref": "#/$defs/Timestamp"
        },
        "updated_at": {
          "$ref": "#/$defs/Timestamp"
        },
        "revision": {
          "type": "integer",
          "minimum": 1
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,62}$"
        },
        "default_locale": {
          "$ref": "#/$defs/Locale"
        },
        "timezone": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "examples": [
            "Asia/Shanghai"
          ]
        },
        "plan": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]*$",
          "x-known-values": [
            "free",
            "pro",
            "team",
            "enterprise"
          ]
        },
        "extensions": {
          "$ref": "#/$defs/Extensions"
        }
      },
      "required": [
        "id",
        "created_at",
        "updated_at",
        "revision",
        "name",
        "slug",
        "default_locale",
        "timezone",
        "plan"
      ],
      "additionalProperties": false
    },
    "WorkspaceMember": {
      "type": "object",
      "properties": {
        "id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "created_at": {
          "$ref": "#/$defs/Timestamp"
        },
        "updated_at": {
          "$ref": "#/$defs/Timestamp"
        },
