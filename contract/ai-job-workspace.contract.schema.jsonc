    "InterviewReportJob": {
      "type": "object",
      "properties": {
        "id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "job_type": {
          "type": "string",
          "const": "interview.report"
        },
        "status": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]*$",
          "x-known-values": [
            "queued",
            "running",
            "succeeded",
            "failed",
            "cancelled",
            "expired"
          ]
        },
        "progress": {
          "$ref": "#/$defs/JobProgress"
        },
        "created_at": {
          "$ref": "#/$defs/Timestamp"
        },
        "started_at": {
          "anyOf": [
            {
              "$ref": "#/$defs/Timestamp"
            },
            {
              "type": "null"
            }
          ]
        },
        "finished_at": {
          "anyOf": [
            {
              "$ref": "#/$defs/Timestamp"
            },
            {
              "type": "null"
            }
          ]
        },
        "expires_at": {
          "anyOf": [
            {
              "$ref": "#/$defs/Timestamp"
            },
            {
              "type": "null"
            }
          ]
        },
        "error": {
          "anyOf": [
            {
              "$ref": "#/$defs/ProblemDetails"
            },
            {
              "type": "null"
            }
          ]
        },
        "request_id": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 8,
              "maxLength": 128
            },
            {
              "type": "null"
            }
          ]
        },
        "extensions": {
          "$ref": "#/$defs/Extensions"
        },
        "session_id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "report_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/OpaqueId"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "id",
        "job_type",
        "status",
        "progress",
        "created_at",
        "session_id"
      ],
      "additionalProperties": false
    },
