    "RealtimeConnectionDescriptor": {
      "type": "object",
      "properties": {
        "session_id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "protocol_version": {
          "type": "string",
          "const": "1.0"
        },
        "ephemeral_token": {
          "type": "string",
          "minLength": 20,
          "maxLength": 8000
        },
        "expires_at": {
          "$ref": "#/$defs/Timestamp"
        },
        "signaling_url": {
          "$ref": "#/$defs/Uri"
        },
        "event_stream_url": {
          "anyOf": [
            {
              "$ref": "#/$defs/Uri"
            },
            {
              "type": "null"
            }
          ]
        },
        "ice_servers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/IceServer"
          },
          "maxItems": 20
        },
        "webrtc": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "data_channel_label": {
              "type": "string",
              "maxLength": 100
            },
            "bundle_policy": {
              "type": "string",
              "enum": [
                "balanced",
                "max-bundle",
                "max-compat"
              ]
            },
            "expected_uplink_tracks": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "audio",
                  "video",
                  "screen"
                ]
              },
              "uniqueItems": true
            },
            "expected_downlink_tracks": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "audio",
                  "video"
                ]
              },
              "uniqueItems": true
            }
          },
          "required": [
            "enabled",
            "data_channel_label",
            "bundle_policy",
            "expected_uplink_tracks",
            "expected_downlink_tracks"
          ],
          "additionalProperties": false
        },
        "fallback": {
          "type": "object",
          "properties": {
            "websocket_url": {
              "anyOf": [
                {
                  "$ref": "#/$defs/Uri"
                },
                {
                  "type": "null"
                }
              ]
            },
            "binary_frame_protocol": {
              "anyOf": [
                {
                  "type": "string",
                  "enum": [
                    "aiws-media-v1"
                  ]
                },
                {
                  "type": "null"
                }
              ]
            },
            "max_frame_bytes": {
              "anyOf": [
                {
                  "type": "integer",
                  "minimum": 1024,
                  "maximum": 16777216
                },
                {
                  "type": "null"
                }
              ]
            }
          },
          "required": [
            "websocket_url"
          ],
          "additionalProperties": false
        },
        "resume_token": {
          "type": "string",
          "minLength": 20,
          "maxLength": 8000
        }
      },
      "required": [
        "session_id",
        "protocol_version",
        "ephemeral_token",
        "expires_at",
        "signaling_url",
        "ice_servers",
        "webrtc",
        "fallback",
        "resume_token"
      ],
      "additionalProperties": false
    },
    "InterviewEventEnvelopeBase": {
      "type": "object",
      "properties": {
        "protocol_version": {
          "type": "string",
          "const": "1.0"
        },
        "event_id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "event_type": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]*$"
        },
        "session_id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "sequence": {
          "type": "integer",
          "minimum": 0
        },
        "ack_sequence": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0
            },
            {
              "type": "null"
            }
          ]
        },
        "occurred_at": {
          "$ref": "#/$defs/Timestamp"
        },
        "trace_id": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 8,
              "maxLength": 128
            },
            {
              "type": "null"
            }
          ]
        },
        "payload": {},
        "extensions": {
          "$ref": "#/$defs/Extensions"
        }
      },
      "required": [
        "protocol_version",
        "event_id",
        "event_type",
        "session_id",
        "sequence",
        "occurred_at",
        "payload"
      ],
      "additionalProperties": false
    },
    "ClientReadyPayload": {
      "type": "object",
      "properties": {
        "client_time": {
          "$ref": "#/$defs/Timestamp"
        },
        "media_ready": {
          "type": "boolean"
        },
        "last_received_sequence": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "client_time",
        "media_ready"
      ],
      "additionalProperties": false
    },
    "UserInterruptPayload": {
      "type": "object",
      "properties": {
        "reason": {
          "type": "string",
          "enum": [
            "barge_in",
            "skip",
            "correction",
            "technical_issue"
          ]
        },
        "stop_output": {
          "type": "boolean",
          "default": true
        }
      },
      "required": [
        "reason",
        "stop_output"
      ],
      "additionalProperties": false
    },
    "SessionEndRequestPayload": {
      "type": "object",
      "properties": {
        "reason": {
          "type": "string",
          "enum": [
            "user_finished",
            "time_limit",
            "technical_issue",
            "user_cancelled"
          ]
        },
        "generate_report": {
          "type": "boolean",
          "default": true
        }
      },
      "required": [
        "reason",
        "generate_report"
      ],
      "additionalProperties": false
    },
    "QualityReportPayload": {
      "type": "object",
      "properties": {
        "rtt_ms": {
          "anyOf": [
            {
              "type": "number",
              "minimum": 0
            },
            {
              "type": "null"
            }
          ]
        },
        "packet_loss_ratio": {
          "anyOf": [
            {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "jitter_ms": {
          "anyOf": [
            {
              "type": "number",
              "minimum": 0
            },
            {
              "type": "null"
            }
          ]
        },
        "audio_level": {
          "anyOf": [
            {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "video_fps": {
          "anyOf": [
            {
              "type": "number",
              "minimum": 0
            },
            {
              "type": "null"
            }
          ]
        },
        "available_outgoing_bitrate_bps": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "SessionStatePayload": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "preparing",
            "ready",
            "connecting",
            "in_progress",
            "ending",
            "processing_report",
            "completed",
            "aborted",
            "failed"
          ]
        },
        "reason": {
          "anyOf": [
            {
              "$ref": "#/$defs/LocalizedMessage"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "status"
      ],
      "additionalProperties": false
    },
    "TranscriptPayload": {
      "type": "object",
      "properties": {
        "segment_id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "speaker": {
          "type": "string",
          "enum": [
            "candidate",
            "interviewer",
            "system"
          ]
        },
        "text": {
          "type": "string",
          "maxLength": 100000
        },
        "start_ms": {
          "type": "integer",
          "minimum": 0
        },
        "end_ms": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0
            },
            {
              "type": "null"
            }
          ]
        },
        "confidence": {
          "anyOf": [
            {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "language": {
          "$ref": "#/$defs/Locale"
        },
        "revision": {
          "type": "integer",
          "minimum": 1
        }
      },
      "required": [
        "segment_id",
        "speaker",
        "text",
        "start_ms",
        "language",
        "revision"
      ],
      "additionalProperties": false
    },
    "InterviewerTextDeltaPayload": {
      "type": "object",
      "properties": {
        "turn_id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "text_delta": {
          "type": "string",
          "maxLength": 100000
        },
        "index": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "turn_id",
        "text_delta",
        "index"
      ],
      "additionalProperties": false
    },
    "InterviewerTextFinalPayload": {
      "type": "object",
      "properties": {
        "turn_id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "text": {
          "type": "string",
          "maxLength": 100000
        },
        "audio_track_expected": {
          "type": "boolean"
        },
        "video_track_expected": {
          "type": "boolean"
        }
      },
      "required": [
        "turn_id",
        "text",
        "audio_track_expected",
        "video_track_expected"
      ],
      "additionalProperties": false
    },
    "AvatarCuePayload": {
      "type": "object",
      "properties": {
        "turn_id": {
          "$ref": "#/$defs/OpaqueId"
        },
        "cue_type": {
          "type": "string",
          "enum": [
            "viseme",
            "expression",
            "gesture",
            "gaze",
            "subtitle_timing"
          ]
        },
        "start_ms": {
          "type": "integer",
          "minimum": 0
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "intensity": {
          "anyOf": [
            {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "data": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "required": [
        "turn_id",
        "cue_type",
        "start_ms",
        "duration_ms",
        "name",
        "data"
      ],
      "additionalProperties": false
    },
    "RealtimeWarningPayload": {
      "type": "object",
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]*$"
        },
        "message": {
