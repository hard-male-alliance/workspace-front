{
  "name": "ai-job-workspace",
  "version": "0.1.0",
  "description": "AI-powered workspace for job seekers, shared by Web and Electron.",
  "private": true,
  "type": "module",
  "license": "GPL-3.0-only",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "pnpm dev:web",
    "dev:web": "pnpm --filter @ai-job-workspace/web dev",
    "dev:desktop": "pnpm --filter @ai-job-workspace/desktop dev",
    "build": "pnpm --filter @ai-job-workspace/web build && pnpm --filter @ai-job-workspace/desktop build",
    "build:web": "pnpm --filter @ai-job-workspace/web build",
    "build:desktop": "pnpm --filter @ai-job-workspace/desktop build",
    "package": "pnpm build && pnpm smoke:desktop",
    "smoke:desktop": "node scripts/desktop-smoke.mjs",
    "preview": "pnpm --filter @ai-job-workspace/web preview",
    "typecheck": "tsc -p tsconfig.node.json --noEmit --pretty false && tsc -p tsconfig.renderer.json --noEmit --pretty false",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:node": "vitest run --project node",
    "test:dom": "vitest run --project dom",
    "test:browser": "vitest run --project browser",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm smoke:desktop"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-react": "^5.1.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^7.3.6",
    "vitest-browser-react": "^2.2.0",
    "vitest": "^4.1.10"
  }
}
