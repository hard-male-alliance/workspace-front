# Electron native OAuth public client ID；这是会被写入 main bundle 的公开标识，不是 secret。
# 必须与 Authorization Server 上登记的 loopback redirect 规则匹配。
AI_JOB_WORKSPACE_OAUTH_CLIENT_ID=workspace-desktop

# 可选诊断上传仍是运行时公开配置；三项均省略时禁用。
# AI_JOB_WORKSPACE_DIAGNOSTICS_PROTOCOL=https
# AI_JOB_WORKSPACE_DIAGNOSTICS_HOSTNAME=diagnostics.example.com
# AI_JOB_WORKSPACE_DIAGNOSTICS_PORT=443
