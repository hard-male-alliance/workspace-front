{
  "name": "@ai-job-workspace/desktop",
  "version": "0.1.0",
  "description": "Secure Electron host for AI Job Workspace.",
  "author": "AI Job Workspace contributors",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && node ../../scripts/check-production-artifacts.mjs --desktop",
    "preview": "electron-vite preview",
    "package": "pnpm build && electron-builder --dir --config electron-builder.yml",
    "dist": "pnpm build && electron-builder --config electron-builder.yml"
  },
  "devDependencies": {
    "@ai-job-workspace/app": "workspace:*",
    "@ai-job-workspace/platform": "workspace:*",
    "@ai-job-workspace/product-api-v2": "workspace:*",
    "@ai-job-workspace/product-runtime": "workspace:*",
    "@electron/fuses": "^2.1.3",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vite": "^7.3.6"
  }
}
